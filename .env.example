# Copia este archivo como .env.local y rellena las claves reales.

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Notion ---
# Base de datos de tareas (32 chars del URL de Notion, sin guiones)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Page id del proyecto en la columna relation Proyecto
NOTION_PROJECT_RELATION_ID=

# --- Nombres exactos de columnas en Notion ---
NOTION_PROP_TITLE=herramienta
NOTION_PROP_DESCRIPTION=Descripción
NOTION_PROP_PRIORITY=Prioridad
NOTION_PROP_CATEGORY=Categoria
NOTION_PROP_PROJECT=Proyecto
NOTION_PROP_TAGS=Etiquetas
NOTION_PROP_CLIENT=Cliente
NOTION_PROP_CLIENT_PROJECT=Proyecto Cliente
NOTION_PROP_TICKET_TYPE=Tipo de Ticket
NOTION_PROP_STATUS=Estado
NOTION_PROP_SPRINT=Sprint

# Fechas a rellenar con el día presente (CSV)
NOTION_DATE_PROPERTIES=Fecha límite,Fecha Inicio Real

# Sprint: BD de sprints (auto-detecta "Actual") o id fijo
NOTION_SPRINT_DATABASE_ID=

# --- Valores por defecto al crear la tarea ---
NOTION_DEFAULT_CLIENT=Bago
NOTION_DEFAULT_CATEGORY=BUG,Frontend
NOTION_DEFAULT_TICKET_TYPE=Bug
NOTION_DEFAULT_STATUS=Sin empezar

# Mapeo prioridad formulario → select Notion
NOTION_PRIORITY_ALTO=Alta
NOTION_PRIORITY_MEDIO=Media
NOTION_PRIORITY_BAJO=Baja

# --- Portal interno de tareas (/tareas) ---
# Usa la misma BD y API de Notion. Opcional: ?proyecto_notion=<page id>
NOTION_PROP_ASSIGNEE=Responsable
NOTION_PROP_PARENT=Link pagina

# BD de Proyectos (para listar proyectos reales; excluye "Nuevo Proyecto")
NOTION_PROJECTS_DATABASE_ID=
NOTION_PROJECTS_TITLE_PROP=Project name

# IDs de Notion de responsables que no aparecen en users.list (CSV, opcional)
# NOTION_EXTRA_ASSIGNEE_IDS=uuid1,uuid2

# --- Propuestas (/propuestas) ---
# Proyecto "Propuestas" (page id de la relacion Proyecto)
NOTION_PROPUESTA_PROJECT_RELATION_ID=3424f339-cf21-80c9-b6d9-e02c4f8c3efa
# Responsables fijos (CSV de ids): Angeles Correa, Cinthia Burbano
NOTION_PROPUESTA_RESPONSABLE_IDS=334d872b-594c-81ab-8fd2-00025b930cba,335d872b-594c-8136-83a5-00021ea2cf93
NOTION_PROPUESTA_STATUS=Por Revisar
NOTION_PROPUESTA_CATEGORY=Propuesta
NOTION_PROPUESTA_TAGS=Propuestas
NOTION_PROPUESTA_PRIORITY=Media
